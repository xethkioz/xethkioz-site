# XETHKIOZ Environment Variables
# Copy to .env and fill with your Supabase credentials
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional client-side admin access gate.
# This is only a casual protection layer. Use Supabase Auth + roles for real production security.
VITE_ADMIN_ACCESS_CODE=

# Optional analytics placeholders
VITE_GA4_ID=
VITE_CLARITY_ID=
VITE_FACEBOOK_PIXEL_ID=
